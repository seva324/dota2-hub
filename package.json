{
  "name": "dota2-hub-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @dota2hub/web",
    "build": "npm run build -w @dota2hub/web",
    "test": "npm run test -w @dota2hub/web",
    "lint": "npm run lint -w @dota2hub/web",
    "build:web": "npm run build -w @dota2hub/web",
    "test:web": "npm run test -w @dota2hub/web",
    "lint:web": "npm run lint -w @dota2hub/web",
    "build:packages": "npm run build -w @dota2hub/shared-types && npm run build -w @dota2hub/api-client",
    "typecheck:packages": "npm run typecheck -w @dota2hub/shared-types && npm run typecheck -w @dota2hub/api-client",
    "build:mp-wechat": "npm run build:packages && npm run build:weapp -w @dota2hub/mp-wechat",
    "typecheck:mp-wechat": "npm run build:packages && npm run typecheck -w @dota2hub/mp-wechat",
    "verify": "npm run build:web && npm run test:web",
    "push:gh": "npm run verify && git push",
    "manual:generate-report": "node scripts/manual-api/generate-report.js",
    "manual:enrich-proplayers": "node scripts/manual-api/enrich-pro-players.js",
    "manual:install-proplayers-audit": "node scripts/manual-api/install-pro-player-audit-log.js",
    "manual:install-team-audit": "node scripts/manual-api/install-team-audit-log.js",
    "manual:backfill-hot-player-history": "node scripts/manual-api/backfill-hot-player-history.js",
    "ops:monitor-backfill-tg": "node scripts/ops/monitor-hot-player-backfill.mjs",
    "ops:monitor-derived-refresh-tg": "node scripts/ops/monitor-derived-refresh.mjs",
    "ops:refresh-derived-data": "node scripts/ops/refresh-derived-data.mjs",
    "ops:cron-refresh-hourly": "node scripts/ops/hourly-cron-refresh.mjs",
    "ops:repair-bo3-news": "node --env-file=.env.vercel scripts/repair-bo3-news-content.mjs",
    "ops:compare-live-hero-latency": "node scripts/ops/compare-live-hero-latency.mjs",
    "ops:monitor-live-hero-tg": "node --env-file=.env.local scripts/ops/monitor-live-hero-score.mjs",
    "ops:mirror-assets": "node scripts/mirror-assets-to-public.mjs",
    "ops:backfill-dltv-team-logos": "node --env-file=.env.vercel scripts/ops/backfill-dltv-team-logos.mjs",
    "ops:audit-neon-branches": "node scripts/ops/audit-neon-branches.mjs",
    "ops:post-news-xhs": "node --env-file=.env.vercel scripts/post-news-to-xhs.mjs",
    "ops:post-reddit-xhs": "node --env-file=.env.vercel scripts/post-reddit-to-xhs.mjs"
  },
  "overrides": {
    "swiper": "12.1.4",
    "axios": "1.15.2",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "node-forge": "1.4.0",
    "flatted": "3.4.2",
    "picomatch": "2.3.2",
    "esbuild": "0.25.12",
    "postcss": "8.5.13",
    "serialize-javascript": "7.0.5",
    "glob": "10.5.0",
    "got": "15.0.3",
    "http-cache-semantics": "4.2.0",
    "html-minifier": "npm:html-minifier-terser@7.2.0",
    "webpack-dev-server": "5.2.3",
    "git-clone": "npm:git-clone-safe@1.2.0",
    "@types/react": "$@types/react",
    "@types/react-dom": "$@types/react-dom",
    "express": {
      "path-to-regexp": "0.1.13"
    },
    "postcss-url": {
      "minimatch": "3.1.5"
    },
    "miniprogram-simulate": {
      "postcss": "8.5.13"
    },
    "sockjs": {
      "uuid": "14.0.0"
    }
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/client": "^7.7.0",
    "better-sqlite3": "^12.6.2",
    "pg": "^8.20.0",
    "redis": "^4.6.0",
    "sql.js": "^1.14.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
