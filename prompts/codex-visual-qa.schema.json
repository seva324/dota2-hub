{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "module": {
      "type": "string",
      "enum": ["team-flyout", "player-profile", "match-detail"]
    },
    "viewport": {
      "type": "string",
      "enum": ["desktop", "mobile"]
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "summary": {
      "type": "string"
    },
    "blocking_issues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "differences": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "area": { "type": "string" },
          "severity": { "type": "string", "enum": ["high", "medium", "low"] },
          "description": { "type": "string" },
          "expected": { "type": "string" },
          "actual": { "type": "string" },
          "suggested_fix": { "type": "string" }
        },
        "required": ["area", "severity", "description", "expected", "actual", "suggested_fix"]
      }
    },
    "top_3_fixes": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 3
    },
    "tdd_acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "regression_risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pass_90_threshold": {
      "type": "boolean"
    }
  },
  "required": ["module", "viewport", "score", "summary", "differences", "top_3_fixes", "pass_90_threshold"]
}
