# Core runtime
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
POSTGRES_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
SITE_BASE_URL=https://your-production-domain.example.com
PUBLIC_SITE_URL=https://your-production-domain.example.com

# Data sync and enrichment
OPENDOTA_API_KEY=your_opendota_api_key
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_TEXT_API_KEY=your_minimax_text_api_key
MINIMAX_API_URL=https://api.minimax.io/anthropic/v1/messages
MINIMAX_MODEL=MiniMax-M2.5
FIRECRAWL_API_KEY=your_firecrawl_api_key

# Optional integrations
REDIS_URL=redis://USER:PASSWORD@HOST:6379
GPT_API_KEY=your_gpt_api_key
TELEGRAM_BOT_TOKEN=123456:telegram-bot-token
TELEGRAM_CHAT_ID=123456789
TG_BOT_TOKEN=123456:telegram-bot-token
TG_CHAT_ID=123456789

# XHS / content automation
LOCAL_LLM_BASE_URL=http://100.109.56.73:1234
LOCAL_LLM_MODEL=google/gemma-4-e4b
LOCAL_LLM_TIMEOUT_MS=45000
XHS_AUTO_POST=false
XHS_AI_REWRITE=true
XHS_POST_PRESET=default
XHS_REVERSE_CLI=xhs
XHS_CODEX_BIN=codex
XHS_CODEX_MODEL=gpt-5.1-codex-mini
XHS_REWRITE_TIMEOUT_MS=45000
XHS_REWRITE_PROMPT_FILE=docs/xhs-community-post-prompt.md
NEWS_TRANSLATE_CODEX_MODEL=gpt-5.1-codex-mini
NEWS_TRANSLATE_OPENROUTER_MODEL=google/gemma-4-31b-it

# Runtime tuning
D2HUB_CRON_MIN_INTERVAL_MIN=0
D2HUB_OPENDOTA_PIPELINE_MIN_INTERVAL_MIN=0
CRON_MIN_INTERVAL_MIN=0
TELEGRAM_TIMEOUT_MS=30000

# Mini program
TARO_APP_API_BASE_URL=https://your-production-domain.example.com
