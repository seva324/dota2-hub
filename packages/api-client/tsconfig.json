{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@dota2hub/shared-types": [
        "../shared-types/dist/index.d.ts"
      ]
    },
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": false,
    "outDir": "./dist",
    "skipLibCheck": true
  },
  "include": [
    "src"
  ]
}
