{
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build:web",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "crons": [
    {
      "path": "/api/cron?action=sync-opendota",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/sync-news",
      "schedule": "30 9 * * *"
    },
    {
      "path": "/api/sync-liquipedia",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron?action=refresh-derived-data-incremental",
      "schedule": "30 14 * * *"
    }
  ]
}
